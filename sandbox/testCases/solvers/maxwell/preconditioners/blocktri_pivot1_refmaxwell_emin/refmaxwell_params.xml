<ParameterList name="MueLu">
  <!-- RefMaxwell MueLu parameters for blocktri_pivot1_refmaxwell_emin -->
  <!-- Energy minimization (emin) on (1,1)/(2,2); CHEBYSHEV smoothers: ratios 20 / 5.4 / 7.0 (fine / edge / nodal). -->

  <!-- ============================================= -->
  <!-- Note: Parameters NOT in this XML file        -->
  <!-- ============================================= -->
  <!-- MrHyDE-specific parameters that must be in YAML:
       - use xml params: true/false (enable XML loading)
       - xml param file: filename (path to this XML file)
       - use lumped M0inv: true/false (MrHyDE builds M0 inverse)
       - hgrad basis name: name (MrHyDE basis information)
       - hcurl basis name: name (MrHyDE basis information)
       - hgrad basis order: number (MrHyDE basis information)
       - hcurl basis order: number (MrHyDE basis information)
  -->

  <!-- The following are provided programmatically by MrHyDE:
       - D0_Matrix (discrete gradient)
       - M1_Matrix (edge mass matrix)
       - M0inv_Matrix (inverse nodal mass, built by MrHyDE)
       - Coordinates (nodal coordinates)
       - Nullspace (optional null space vectors)
  -->

  <!-- ============================================= -->
  <!-- Core verbosity and output control            -->
  <!-- ============================================= -->
  <Parameter name="verbosity" type="string" value="none"/>
  <Parameter name="print initial parameters" type="bool" value="false"/>
  <Parameter name="output filename" type="string" value=""/>
  <Parameter name="parameterlist: syntax" type="string" value="muelu"/>

  <!-- ============================================= -->
  <!-- RefMaxwell space configuration               -->
  <!-- ============================================= -->
  <Parameter name="refmaxwell: space number" type="int" value="1"/>

  <!-- ============================================= -->
  <!-- RefMaxwell mode and behavior                 -->
  <!-- ============================================= -->
  <Parameter name="refmaxwell: mode" type="string" value="additive"/>
  <Parameter name="refmaxwell: use as preconditioner" type="bool" value="true"/>
  <Parameter name="refmaxwell: enable reuse" type="bool" value="true"/>
  <Parameter name="refmaxwell: disable addon" type="bool" value="false"/>
  <Parameter name="refmaxwell: disable addon 22" type="bool" value="false"/>
  <Parameter name="refmaxwell: skip first (2,2) level" type="bool" value="false"/>
  <Parameter name="refmaxwell: dump matrices" type="bool" value="false"/>

  <!-- ============================================= -->
  <!-- Coarse grid and iteration control            -->
  <!-- ============================================= -->
  <Parameter name="refmaxwell: max coarse size" type="int" value="500"/>
  <Parameter name="refmaxwell: num iters coarse 11" type="int" value="1"/>
  <Parameter name="refmaxwell: num iters 22" type="int" value="1"/>

  <!-- ============================================= -->
  <!-- Boundary condition application               -->
  <!-- ============================================= -->
  <Parameter name="refmaxwell: apply BCs to Anodal" type="bool" value="false"/>
  <Parameter name="refmaxwell: apply BCs to coarse 11" type="bool" value="true"/>
  <Parameter name="refmaxwell: apply BCs to 22" type="bool" value="true"/>

  <!-- ============================================= -->
  <!-- Parallel and performance settings            -->
  <!-- ============================================= -->
  <Parameter name="use kokkos refactor" type="bool" value="false"/>
  <Parameter name="half precision" type="bool" value="false"/>
  <Parameter name="refmaxwell: async transfers" type="bool" value="false"/>
  <Parameter name="refmaxwell: subsolves on subcommunicators" type="bool" value="true"/>
  <Parameter name="refmaxwell: subsolves striding" type="int" value="1"/>
  <Parameter name="sync timers" type="bool" value="false"/>

  <!-- ============================================= -->
  <!-- Matrix operations                            -->
  <!-- ============================================= -->
  <Parameter name="multigrid algorithm" type="string" value="unsmoothed"/>
  <Parameter name="transpose: use implicit" type="bool" value="false"/>
  <Parameter name="rap: triple product" type="bool" value="false"/>
  <Parameter name="rap: fix zero diagonals" type="bool" value="true"/>
  <Parameter name="rap: fix zero diagonals threshold" type="double" value="0.0"/>
  <Parameter name="fuse prolongation and update" type="bool" value="true"/>

  <!-- ============================================= -->
  <!-- Aggregation settings (top-level RefMaxwell)   -->
  <!-- ============================================= -->
  <Parameter name="aggregation: type" type="string" value="uncoupled"/>
  <Parameter name="aggregation: drop tol" type="double" value="0.35"/>
  <Parameter name="aggregation: drop scheme" type="string" value="distance laplacian"/>
  <Parameter name="aggregation: distance laplacian algo" type="string" value="scaled cut"/>
  <Parameter name="aggregation: min agg size" type="int" value="2"/>
  <Parameter name="aggregation: max agg size" type="int" value="-1"/>
  <Parameter name="aggregation: match ML phase1" type="bool" value="false"/>
  <Parameter name="aggregation: match ML phase2a" type="bool" value="false"/>
  <Parameter name="aggregation: match ML phase2b" type="bool" value="false"/>
  <Parameter name="aggregation: export visualization data" type="bool" value="false"/>
  <Parameter name="refmaxwell: row sum drop tol (1,1)" type="double" value="-1.0"/>

  <!-- ============================================= -->
  <!-- Top-level smoother (fine level)              -->
  <!-- ============================================= -->
  <Parameter name="smoother: type" type="string" value="CHEBYSHEV"/>
  <Parameter name="smoother: pre type" type="string" value="NONE"/>
  <Parameter name="smoother: post type" type="string" value="NONE"/>
  <ParameterList name="smoother: params">
    <Parameter name="chebyshev: degree" type="int" value="2"/>
    <Parameter name="chebyshev: ratio eigenvalue" type="double" value="20.0"/>
    <Parameter name="chebyshev: eigenvalue max iterations" type="int" value="10"/>
    <Parameter name="chebyshev: algorithm" type="string" value="opt_fourth"/>
    <Parameter name="chebyshev: use native spmv" type="bool" value="false"/>
  </ParameterList>

  <!-- ============================================= -->
  <!-- (1,1) block hierarchy - Edge space           -->
  <!-- ============================================= -->
  <ParameterList name="refmaxwell: 11list">
    <Parameter name="verbosity" type="string" value="none"/>
    <Parameter name="print initial parameters" type="bool" value="false"/>
    <Parameter name="number of equations" type="int" value="3"/>

    <!-- Smoother for (1,1) block -->
    <Parameter name="smoother: type" type="string" value="CHEBYSHEV"/>
    <ParameterList name="smoother: params">
      <Parameter name="chebyshev: degree" type="int" value="2"/>
      <Parameter name="chebyshev: ratio eigenvalue" type="double" value="5.4"/>
      <Parameter name="chebyshev: eigenvalue max iterations" type="int" value="10"/>
      <Parameter name="chebyshev: algorithm" type="string" value="opt_fourth"/>
      <Parameter name="chebyshev: use native spmv" type="bool" value="false"/>
    </ParameterList>

    <!-- Coarse solver for (1,1) block -->
    <Parameter name="coarse: type" type="string" value="KLU"/>
    <Parameter name="coarse: max size" type="int" value="500"/>

    <!-- Multigrid hierarchy settings for (1,1) block -->
    <Parameter name="max levels" type="int" value="10"/>
    <Parameter name="multigrid algorithm" type="string" value="emin"/>

    <Parameter name="fuse prolongation and update" type="bool" value="true"/>

    <!-- Aggregation for (1,1) block -->
    <Parameter name="aggregation: type" type="string" value="uncoupled"/>
    <Parameter name="aggregation: drop tol" type="double" value="0.02"/>
    <Parameter name="aggregation: min agg size" type="int" value="2"/>
    <Parameter name="aggregation: max agg size" type="int" value="-1"/>

    <!-- Repartitioning (1,1) -->
    <Parameter name="repartition: enable" type="bool" value="true"/>
    <Parameter name="repartition: partitioner" type="string" value="zoltan2"/>
    <Parameter name="repartition: start level" type="int" value="1"/>
    <Parameter name="repartition: target rows per thread" type="int" value="3750"/>
    <Parameter name="repartition: min rows per thread" type="int" value="250"/>
    <Parameter name="repartition: max imbalance" type="double" value="1.1"/>
    <Parameter name="repartition: remap parts" type="bool" value="true"/>
    <Parameter name="repartition: rebalance P and R" type="bool" value="false"/>
    <Parameter name="repartition: print partition distribution" type="bool" value="true"/>
    <ParameterList name="repartition: params">
      <Parameter name="algorithm" type="string" value="multijagged"/>
    </ParameterList>
  </ParameterList>

  <!-- ============================================= -->
  <!-- (2,2) block hierarchy - Nodal space          -->
  <!-- ============================================= -->
  <ParameterList name="refmaxwell: 22list">
    <Parameter name="verbosity" type="string" value="none"/>
    <Parameter name="print initial parameters" type="bool" value="false"/>

    <!-- Smoother for (2,2) block -->
    <Parameter name="smoother: type" type="string" value="CHEBYSHEV"/>
    <ParameterList name="smoother: params">
      <Parameter name="chebyshev: degree" type="int" value="2"/>
      <Parameter name="chebyshev: ratio eigenvalue" type="double" value="7.0"/>
      <Parameter name="chebyshev: eigenvalue max iterations" type="int" value="10"/>
      <Parameter name="chebyshev: algorithm" type="string" value="opt_fourth"/>
      <Parameter name="chebyshev: use native spmv" type="bool" value="false"/>
    </ParameterList>

    <!-- Coarse solver for (2,2) block -->
    <Parameter name="coarse: type" type="string" value="KLU"/>
    <Parameter name="coarse: max size" type="int" value="500"/>

    <!-- Multigrid hierarchy settings for (2,2) block -->
    <Parameter name="max levels" type="int" value="10"/>
    <Parameter name="multigrid algorithm" type="string" value="emin"/>

    <Parameter name="fuse prolongation and update" type="bool" value="true"/>

    <!-- Aggregation for (2,2) block -->
    <Parameter name="aggregation: type" type="string" value="uncoupled"/>
    <Parameter name="aggregation: drop tol" type="double" value="0.02"/>
    <Parameter name="aggregation: min agg size" type="int" value="2"/>
    <Parameter name="aggregation: max agg size" type="int" value="-1"/>

    <!-- Repartitioning (2,2) -->
    <Parameter name="repartition: enable" type="bool" value="true"/>
    <Parameter name="repartition: partitioner" type="string" value="zoltan2"/>
    <Parameter name="repartition: start level" type="int" value="1"/>
    <Parameter name="repartition: target rows per thread" type="int" value="15000"/>
    <Parameter name="repartition: min rows per thread" type="int" value="1000"/>
    <Parameter name="repartition: max imbalance" type="double" value="1.1"/>
    <Parameter name="repartition: remap parts" type="bool" value="true"/>
    <Parameter name="repartition: rebalance P and R" type="bool" value="false"/>
    <Parameter name="repartition: print partition distribution" type="bool" value="true"/>
    <ParameterList name="repartition: params">
      <Parameter name="algorithm" type="string" value="multijagged"/>
    </ParameterList>
  </ParameterList>

</ParameterList>
