<ParameterList name="MueLu">
  <!-- Mirrors blocktri_pivot1_refmaxwell_cheb RefMaxwell Settings in XML -->

  <!-- MrHyDE-specific (YAML): use xml params, xml param file, use lumped M0inv, hgrad/hcurl names and orders -->

  <Parameter name="verbosity" type="string" value="none"/>
  <Parameter name="print initial parameters" type="bool" value="false"/>
  <Parameter name="output filename" type="string" value=""/>
  <Parameter name="parameterlist: syntax" type="string" value="muelu"/>

  <Parameter name="refmaxwell: space number" type="int" value="1"/>

  <Parameter name="refmaxwell: mode" type="string" value="additive"/>
  <Parameter name="refmaxwell: use as preconditioner" type="bool" value="true"/>
  <Parameter name="refmaxwell: enable reuse" type="bool" value="true"/>
  <Parameter name="refmaxwell: disable addon" type="bool" value="false"/>
  <Parameter name="refmaxwell: disable addon 22" type="bool" value="false"/>
  <Parameter name="refmaxwell: skip first (2,2) level" type="bool" value="false"/>
  <Parameter name="refmaxwell: dump matrices" type="bool" value="false"/>

  <Parameter name="refmaxwell: max coarse size" type="int" value="200"/>
  <Parameter name="refmaxwell: num iters coarse 11" type="int" value="1"/>
  <Parameter name="refmaxwell: num iters 22" type="int" value="1"/>

  <Parameter name="refmaxwell: apply BCs to Anodal" type="bool" value="false"/>
  <Parameter name="refmaxwell: apply BCs to coarse 11" type="bool" value="true"/>
  <Parameter name="refmaxwell: apply BCs to 22" type="bool" value="true"/>

  <Parameter name="use kokkos refactor" type="bool" value="false"/>
  <Parameter name="half precision" type="bool" value="false"/>
  <Parameter name="refmaxwell: async transfers" type="bool" value="false"/>
  <Parameter name="refmaxwell: subsolves on subcommunicators" type="bool" value="false"/>
  <Parameter name="refmaxwell: subsolves striding" type="int" value="1"/>
  <Parameter name="sync timers" type="bool" value="false"/>

  <Parameter name="multigrid algorithm" type="string" value="unsmoothed"/>
  <Parameter name="transpose: use implicit" type="bool" value="false"/>
  <Parameter name="rap: triple product" type="bool" value="false"/>
  <Parameter name="rap: fix zero diagonals" type="bool" value="true"/>
  <Parameter name="rap: fix zero diagonals threshold" type="double" value="0.0"/>
  <Parameter name="fuse prolongation and update" type="bool" value="true"/>

  <Parameter name="aggregation: type" type="string" value="uncoupled"/>
  <Parameter name="aggregation: drop tol" type="double" value="0.001"/>
  <Parameter name="aggregation: drop scheme" type="string" value="classical"/>
  <Parameter name="aggregation: distance laplacian algo" type="string" value="default"/>
  <Parameter name="aggregation: min agg size" type="int" value="2"/>
  <Parameter name="aggregation: max agg size" type="int" value="-1"/>
  <Parameter name="aggregation: match ML phase1" type="bool" value="false"/>
  <Parameter name="aggregation: match ML phase2a" type="bool" value="false"/>
  <Parameter name="aggregation: match ML phase2b" type="bool" value="false"/>
  <Parameter name="aggregation: export visualization data" type="bool" value="false"/>
  <Parameter name="refmaxwell: row sum drop tol (1,1)" type="double" value="-1.0"/>

  <Parameter name="smoother: type" type="string" value="CHEBYSHEV"/>
  <Parameter name="smoother: pre type" type="string" value="NONE"/>
  <Parameter name="smoother: post type" type="string" value="NONE"/>
  <ParameterList name="smoother: params">
    <Parameter name="chebyshev: degree" type="int" value="2"/>
    <Parameter name="chebyshev: ratio eigenvalue" type="double" value="1.1"/>
    <Parameter name="chebyshev: min eigenvalue" type="double" value="0.1"/>
    <Parameter name="eigen-analysis: type" type="string" value="power-method"/>
    <Parameter name="chebyshev: eigenvalue max iterations" type="int" value="15"/>
  </ParameterList>

  <ParameterList name="refmaxwell: 11list">
    <Parameter name="verbosity" type="string" value="none"/>
    <Parameter name="print initial parameters" type="bool" value="false"/>
    <Parameter name="smoother: type" type="string" value="CHEBYSHEV"/>
    <ParameterList name="smoother: params">
      <Parameter name="chebyshev: degree" type="int" value="2"/>
      <Parameter name="chebyshev: ratio eigenvalue" type="double" value="1.1"/>
      <Parameter name="chebyshev: min eigenvalue" type="double" value="0.1"/>
      <Parameter name="eigen-analysis: type" type="string" value="power-method"/>
      <Parameter name="chebyshev: eigenvalue max iterations" type="int" value="15"/>
    </ParameterList>
    <Parameter name="coarse: type" type="string" value="KLU"/>
    <Parameter name="coarse: max size" type="int" value="300"/>
    <Parameter name="max levels" type="int" value="10"/>
    <Parameter name="multigrid algorithm" type="string" value="sa"/>
    <Parameter name="aggregation: type" type="string" value="uncoupled"/>
    <Parameter name="aggregation: drop tol" type="double" value="0.001"/>
    <Parameter name="aggregation: min agg size" type="int" value="2"/>
    <Parameter name="aggregation: max agg size" type="int" value="-1"/>
  </ParameterList>

  <ParameterList name="refmaxwell: 22list">
    <Parameter name="verbosity" type="string" value="none"/>
    <Parameter name="print initial parameters" type="bool" value="false"/>
    <Parameter name="smoother: type" type="string" value="RELAXATION"/>
    <ParameterList name="smoother: params">
      <Parameter name="relaxation: type" type="string" value="Jacobi"/>
      <Parameter name="relaxation: sweeps" type="int" value="2"/>
      <Parameter name="relaxation: damping factor" type="double" value="0.66"/>
    </ParameterList>
    <Parameter name="coarse: type" type="string" value="KLU"/>
    <Parameter name="coarse: max size" type="int" value="300"/>
    <Parameter name="max levels" type="int" value="10"/>
    <Parameter name="multigrid algorithm" type="string" value="sa"/>
    <Parameter name="aggregation: type" type="string" value="uncoupled"/>
    <Parameter name="aggregation: drop tol" type="double" value="0.001"/>
    <Parameter name="aggregation: min agg size" type="int" value="2"/>
    <Parameter name="aggregation: max agg size" type="int" value="-1"/>
  </ParameterList>

</ParameterList>
